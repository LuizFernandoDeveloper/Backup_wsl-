<Window x:Class="MegaBackupWsl.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mega Backup WSL"
        Width="1120"
        Height="760"
        MinWidth="960"
        MinHeight="640"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Mega Backup WSL"
                               FontSize="24"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Interface para organizar backups, validar templates e executar rotinas seguras sem decorar parametros."
                               Margin="0,5,0,0"
                               Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#ECFDF5"
                        BorderBrush="#99F6E4"
                        BorderThickness="1"
                        CornerRadius="999"
                        Padding="14,7"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText"
                               Text="Pronto"
                               Foreground="{StaticResource AccentDarkBrush}"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,14,0,14"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="160" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="BackupRoot" FontWeight="SemiBold" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="SourceVhdx" FontWeight="SemiBold" />
                <TextBlock Grid.Row="0" Grid.Column="2" Text="BackupMode" FontWeight="SemiBold" />
                <TextBlock Grid.Row="0" Grid.Column="3" Text="QualityGate" FontWeight="SemiBold" />

                <DockPanel Grid.Row="1" Grid.Column="0" Margin="0,6,14,0">
                    <Button DockPanel.Dock="Right"
                            Content="..."
                            Width="38"
                            Margin="8,0,0,0"
                            Style="{StaticResource SecondaryButton}"
                            Click="BrowseBackupRoot_Click" />
                    <TextBox x:Name="BackupRootTextBox"
                             Text="F:\Backup\WSl_backup" />
                </DockPanel>

                <DockPanel Grid.Row="1" Grid.Column="1" Margin="0,6,14,0">
                    <Button DockPanel.Dock="Right"
                            Content="..."
                            Width="38"
                            Margin="8,0,0,0"
                            Style="{StaticResource SecondaryButton}"
                            Click="BrowseSourceVhdx_Click" />
                    <TextBox x:Name="SourceVhdxTextBox"
                             Text="D:\disk-removivel-wsl2\WSL_Drives.vhdx" />
                </DockPanel>

                <ComboBox x:Name="BackupModeComboBox"
                          Grid.Row="1"
                          Grid.Column="2"
                          Margin="0,6,14,0"
                          SelectedIndex="0">
                    <ComboBoxItem Content="All" />
                    <ComboBoxItem Content="Distros" />
                    <ComboBoxItem Content="Vhdx" />
                </ComboBox>

                <ComboBox x:Name="QualityGateComboBox"
                          Grid.Row="1"
                          Grid.Column="3"
                          Margin="0,6,0,0"
                          SelectedIndex="1">
                    <ComboBoxItem Content="Basic" />
                    <ComboBoxItem Content="Standard" />
                    <ComboBoxItem Content="Template" />
                </ComboBox>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,14,0">
                <StackPanel>
                    <TextBlock Text="Acoes Rapidas"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12" />

                    <Button Content="Simular Organizacao"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,0,8"
                            Click="DryRunOrganize_Click" />
                    <Button Content="Organizar Diretorios"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,0,14"
                            Click="OrganizeRuns_Click" />

                    <Separator Margin="0,0,0,14" />

                    <Button Content="DryRun Completo"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,0,8"
                            Click="DryRunBackup_Click" />
                    <Button Content="Saude Das Distros"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,0,8"
                            Click="HealthOnly_Click" />
                    <Button Content="Full Template"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,0,14"
                            Click="FullTemplate_Click" />

                    <Separator Margin="0,0,0,14" />

                    <Button x:Name="StopButton"
                            Content="Parar Processo"
                            Style="{StaticResource SecondaryButton}"
                            IsEnabled="False"
                            Click="StopProcess_Click" />

                    <TextBlock Text="As acoes chamam o script PowerShell do projeto. Backup real pode desligar o WSL."
                               Margin="0,16,0,0"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                        <Button DockPanel.Dock="Right"
                                Content="Limpar"
                                Style="{StaticResource SecondaryButton}"
                                Click="ClearLog_Click" />
                        <TextBlock Text="Log"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </DockPanel>

                    <TextBox x:Name="LogTextBox"
                             Grid.Row="1"
                             FontFamily="Cascadia Mono, Consolas"
                             FontSize="12"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"
                             Background="#0F172A"
                             Foreground="#E2E8F0"
                             BorderThickness="0"
                             Padding="12" />
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="3"
                   x:Name="ScriptPathText"
                   Margin="2,12,2,0"
                   Foreground="{StaticResource MutedTextBrush}"
                   TextTrimming="CharacterEllipsis" />
    </Grid>
</Window>
